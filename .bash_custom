# Custom:
# MrKoby07 was hereee

# Typofix and other small update commands
alias vencord='echo Starting Vencord installer... && echo Elevating with sudo... && sudo "$HOME/.local/bin/vencord"'
alias sudp='sudo'
alias masterrc="bash <(curl -fsSL https://raw.githubusercontent.com/Master3307/masterrc/refs/heads/master/install.sh)"
alias profilerc="bash '$HOME/.masterrc/profile.sh'"

# Discord update command
discord-update() {
  local api_url final_url remote_ver installed_ver tmp

  api_url="https://discord.com/api/download/stable?platform=linux&format=deb"
  installed_ver="$(dpkg-query -W -f='${Version}' discord 2>/dev/null || true)"
  final_url="$(curl -fsSLI -o /dev/null -w '%{url_effective}' "$api_url")"
  remote_ver="$(printf '%s\n' "$final_url" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -n1)"

  if [ -z "$remote_ver" ]; then
    echo "Could not determine latest Discord version."
    return 1
  fi

  if [ -n "$installed_ver" ] && dpkg --compare-versions "$installed_ver" ge "$remote_ver"; then
    echo "Discord is already up to date ($installed_ver)."
    return 0
  fi

  echo "New Discord version found: $remote_ver"
  tmp="$(mktemp /tmp/discord-XXXXXX.deb)"
  wget -q --show-progress "$api_url" -O "$tmp"
  sudo apt install -y "$tmp"
  rm -f "$tmp"
}

# This is the Main update command. It updates pretty much everything.
# We got: APT, Flatpak, Discord
aptt() {
  echo "------------------------------"
  echo "Authenticating..."
  echo
  sudo -v || return 1
  echo
  echo "------------------------------"
  echo "Updating Flatpak..."
  echo
  flatpak update -y --noninteractive | awk '/end-of-life/ { skip=1 } skip && /^$/ { skip=0; next } !skip'
  echo
  echo "------------------------------"
  echo "Updating APT..."
  echo
  sudo apt update || return 1
  echo
  echo "------------------------------"
  echo "Checking Discord..."
  echo

  installed_ver="$(dpkg-query -W -f='${Version}' discord 2>/dev/null || true)"
  final_url="$(curl -fsSLI -o /dev/null -w '%{url_effective}' "$api_url")" || return 1
  remote_ver="$(grep -oE '[0-9]+\.[0-9]+\.[0-9]+' <<< "$final_url" | head -n1)"

  if [ -z "$remote_ver" ]; then
    echo "Could not determine latest Discord version."
  elif [ -n "$installed_ver" ] && dpkg --compare-versions "$installed_ver" eq "$remote_ver"; then
    echo "Discord is already up to date ($installed_ver)."
  else
    echo "Installing Discord $remote_ver..."
    tmp="$(mktemp /tmp/discord-XXXXXX.deb)" || return 1
    wget -q --show-progress "$api_url" -O "$tmp" || { rm -f "$tmp"; return 1; }
    sudo apt install -y "$tmp" || { rm -f "$tmp"; return 1; }
    rm -f "$tmp"
  fi

  echo "New Discord version found: $remote_ver"
  tmp="$(mktemp /tmp/discord-XXXXXX.deb)"
  wget -q --show-progress "$api_url" -O "$tmp"
  sudo apt install -y "$tmp"
  rm -f "$tmp"
  echo
  echo "------------------------------"
  echo "Doing upgrade..."
  echo
  sudo apt upgrade || return 1
  echo
  echo "------------------------------"
  echo "Doing full-upgrade..."
  echo
  sudo apt full-upgrade || return 1
  echo
  echo "------------------------------"
  echo "Doing autoremove..."
  echo
  sudo apt autoremove
}

typewriter() {
  local text="$1"
  local delay="${2:-0.03}"
  local i char
  while IFS= read -r -n1 char; do
    printf "%s" "$char"
    sleep "$delay"
  done <<< "$text"
  printf "\n"
}

user_name="${USER:-MrKoby07}"
msg="$(printf '\033[31m- \033[0;33mWelcome to the Terminal \033[1;35m%s\033[0m \033[31m-\033[0m' "$user_name")"

rand_typewriter() {
  local text="$1"
  local delay="${2:-0.03}"
  local i char
  while IFS= read -r -n1 char; do
    printf "%s" "$char"
    sleep "$delay"
  done <<< "$text"
  printf "\n"
}

qmsg=$'\033[0;36mWhat magical thing might you do today?\033[0m'

echo
sudo nerdfetch
echo
fortune -a
echo
echo
typewriter "$msg" 0.01
echo
rand_typewriter "$qmsg" 0.01

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
